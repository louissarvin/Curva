{
  "name": "curva-backend",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun index.ts",
    "dev": "bun --watch index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:push": "bunx prisma db push --config prisma/prisma.config.ts && bunx prisma generate --config prisma/prisma.config.ts",
    "db:pull": "bunx prisma db pull --config prisma/prisma.config.ts",
    "db:generate": "bunx prisma generate --config prisma/prisma.config.ts",
    "db:migrate": "bunx prisma migrate dev --name init --config prisma/prisma.config.ts",
    "generate:secrets": "bun scripts/generate-secrets.ts",
    "prewarm:models": "bun scripts/prewarm-models.ts",
    "verify:qvac-models": "bun scripts/verify-qvac-models.ts",
    "preflight": "bun scripts/preflight.ts",
    "treasury:setup": "bun scripts/setup-treasury.ts",
    "fund:peers": "bun scripts/fund-peers.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "axios": "^1.7.9",
    "b4a": "^1.8.1",
    "corestore": "^7.11.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "fastify": "^5.6.0",
    "hypercore-crypto": "^3.7.0",
    "hyperdrive": "^13.3.3",
    "hyperswarm": "^4.17.0",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "prisma": "^7.0.0",
    "typescript": "^5.7.3"
  }
}
