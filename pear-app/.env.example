# Curva pear-app runtime environment
#
# Copy to `.env` and adjust. The pear-app itself does NOT auto-load .env;
# these flags must be set in the shell that launches `npm start` or
# `npm run demo:4peer`. The demo:4peer script (scripts/demo-4peer.js) will
# force the CURVA_* flags on when spawning electron-forge unless already set.

# =============================================================================
# Wallet
# =============================================================================
# Dev shortcut: skips the PasscodePrompt on first boot by using this string as
# the passcode. Remove for real use; the WDK secret manager encrypts the seed
# at rest via PBKDF2 + XSalsa20-Poly1305.
DEV_WALLET_PASSCODE=curva-dev-pw

# =============================================================================
# Feature flags (default off unless a demo runner forces them on)
# =============================================================================
# Host-side flags. Peers see the produced state via Autobase replication and
# do not need to set these locally.

# QVAC LLM commentator (Qwen3 0.6B q4, ~364 MB opt-in download).
CURVA_QVAC_COMMENTATOR_ENABLED=false

# QVAC Whisper speech-to-text streaming into commentary captions.
# See memory/impl_whisper.md for the docs-verified transcribeStream pipeline.
CURVA_QVAC_STT_ENABLED=false

# Pre-recorded WAV fallback for the STT pipeline when live audio capture is
# unavailable on the current runtime (Bare has no browser MediaStream).
# Path is relative to the pear-app root.
CURVA_COMMENTATOR_WAV_FALLBACK=./assets/commentary.wav

# Match prediction pools: host-signed pool opening + EIP-3009 stake entries.
CURVA_PREDICTIONS_ENABLED=false

# On-chain attendance passes: host-signed off-chain credentials.
CURVA_ATTENDANCE_ENABLED=false

# Blind peering: register room Autobases with public blind peers so rooms
# survive host disconnect.
CURVA_BLIND_PEERING_ENABLED=true

# Delegated QVAC inference: host publishes provider pubkey so light peers can
# offload LLM / STT / TTS work over Hyperswarm.
CURVA_DELEGATED_INFERENCE_ENABLED=true

# =============================================================================
# Optional overrides
# =============================================================================
# Human-readable title used by the commentator prompt template. Falls back to
# the room slug when unset.
# CURVA_MATCH_TITLE=Argentina vs Italy - Round of 16

# Force the clip thumbnail generator to use the placeholder image (skip ffmpeg).
# Useful in CI or headless environments.
# CURVA_CLIP_THUMBS_FFMPEG=off

# =============================================================================
# Demo mode (D1/D2 pitch flags)
# =============================================================================
# Master demo switch for the July 15 pitch. When true, the two child flags
# below default to true unless explicitly overridden. Off in normal use.
CURVA_DEMO_MODE=false

# When true AND CURVA_ATTENDANCE_ENABLED=true AND you are the host, the room
# playhead hook auto-mints one attendance pass per rostered peer at kickoff
# (match_time_ms >= 0). Fires once per room open. See memo:
#   memory/impl_attendance_prediction.md
# Defaults to CURVA_DEMO_MODE when unset.
# CURVA_ATTENDANCE_AUTOISSUE=true

# When true AND CURVA_PREDICTIONS_ENABLED=true AND you are the host, the room
# playhead hook auto-opens a winner-only pool at t=2s and auto-publishes the
# result at t=90m, then POSTs /predictions/force-settle/:poolId so the backend
# settlement worker runs synchronously.
# Defaults to CURVA_DEMO_MODE when unset.
# CURVA_PREDICTIONS_AUTOOPEN=true

# Bearer token required by the backend's POST /predictions/force-settle/:poolId
# debug route. Never ship a real token in a production build. Leave unset
# for normal use.
# CURVA_DEBUG_BEARER=change-me
