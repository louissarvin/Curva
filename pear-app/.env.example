# Curva pear-app runtime environment
#
# Copy to `.env` and adjust. The pear-app itself does NOT auto-load .env;
# these flags must be set in the shell that launches `npm start` or
# `npm run demo:4peer`. The demo:4peer script (scripts/demo-4peer.js) will
# force the CURVA_* flags on when spawning electron-forge unless already set.

# =============================================================================
# Wallet
# =============================================================================
# Dev shortcut: skips the PasscodePrompt on first boot by using this string as
# the passcode. Remove for real use; the WDK secret manager encrypts the seed
# at rest via PBKDF2 + XSalsa20-Poly1305.
DEV_WALLET_PASSCODE=curva-dev-pw

# =============================================================================
# Feature flags (default off unless a demo runner forces them on)
# =============================================================================
# Host-side flags. Peers see the produced state via Autobase replication and
# do not need to set these locally.

# QVAC LLM commentator (Qwen3 0.6B q4, ~364 MB opt-in download).
CURVA_QVAC_COMMENTATOR_ENABLED=false

# QVAC Whisper speech-to-text streaming into commentary captions.
# See memory/impl_whisper.md for the docs-verified transcribeStream pipeline.
CURVA_QVAC_STT_ENABLED=false

# Pre-recorded WAV fallback for the STT pipeline when live audio capture is
# unavailable on the current runtime (Bare has no browser MediaStream).
# Path is relative to the pear-app root.
CURVA_COMMENTATOR_WAV_FALLBACK=./assets/commentary.wav

# Match prediction pools: host-signed pool opening + EIP-3009 stake entries.
CURVA_PREDICTIONS_ENABLED=false

# On-chain attendance passes: host-signed off-chain credentials.
CURVA_ATTENDANCE_ENABLED=false

# Blind peering: register room Autobases with public blind peers so rooms
# survive host disconnect.
CURVA_BLIND_PEERING_ENABLED=true

# Delegated QVAC inference: host publishes provider pubkey so light peers can
# offload LLM / STT / TTS work over Hyperswarm.
CURVA_DELEGATED_INFERENCE_ENABLED=true

# =============================================================================
# Optional overrides
# =============================================================================
# Human-readable title used by the commentator prompt template. Falls back to
# the room slug when unset.
# CURVA_MATCH_TITLE=Argentina vs Italy - Round of 16

# Force the clip thumbnail generator to use the placeholder image (skip ffmpeg).
# Useful in CI or headless environments.
# CURVA_CLIP_THUMBS_FFMPEG=off

# =============================================================================
# Demo mode (D1/D2 pitch flags)
# =============================================================================
# Master demo switch for the July 15 pitch. When true, the two child flags
# below default to true unless explicitly overridden. Off in normal use.
CURVA_DEMO_MODE=false

# When true AND CURVA_ATTENDANCE_ENABLED=true AND you are the host, the room
# playhead hook auto-mints one attendance pass per rostered peer at kickoff
# (match_time_ms >= 0). Fires once per room open. See memo:
#   memory/impl_attendance_prediction.md
# Defaults to CURVA_DEMO_MODE when unset.
# CURVA_ATTENDANCE_AUTOISSUE=true

# When true AND CURVA_PREDICTIONS_ENABLED=true AND you are the host, the room
# playhead hook auto-opens a winner-only pool at t=2s and auto-publishes the
# result at t=90m, then POSTs /predictions/force-settle/:poolId so the backend
# settlement worker runs synchronously.
# Defaults to CURVA_DEMO_MODE when unset.
# CURVA_PREDICTIONS_AUTOOPEN=true

# Bearer token required by the backend's POST /predictions/force-settle/:poolId
# debug route. Never ship a real token in a production build. Leave unset
# for normal use.
# CURVA_DEBUG_BEARER=change-me


  # =============================================================================
  # WAVE 2 - QVAC voice coach + observability
  # =============================================================================
  # The voice-controlled coach chains STT + RAG + LLM + MCP + TTS into one
  # push-to-talk turn. Requires CURVA_QVAC_COMMENTATOR_ENABLED=true above so
  # the shared Qwen3 LLM handle is available. Renderer binds Space bar to the
  # push-to-talk gesture. Off by default; toggle on the panel to load models.

  # TTS via Supertonic (multilingual EN/IT/ID). Used by goal announcer AND
  # by the voice-coach reply playback AND by the goal pipeline announcements.
  CURVA_QVAC_TTS_ENABLED=false

  # Locale for one-shot TTS calls when not explicitly set at call time.
  # CURVA_QVAC_TTS_LOCALE=en

  # Comma-separated locales the goal pipeline fans out to when speaking.
  # Each locale gets its own translated announcement + streaming TTS chunk.
  # CURVA_QVAC_TTS_LOCALES=en,it,id
  
  # LLM chat translator fallback (Qwen3) when Bergamot pair is missing.
  CURVA_QVAC_LLM_TRANSLATE_ENABLED=false

  # Hypertrace + Prometheus observability. Exposes trace_counter,
  # hypercore_*, hyperswarm_*, hyperdht_*, udx_* gauges via a LOOPBACK-ONLY
  # HTTP server at 127.0.0.1:<port>/metrics. DiagnosticsPanel Metrics tab
  # polls this endpoint every 5s while it is open. Default port 4343.
  CURVA_OBSERVABILITY_ENABLED=false
  CURVA_PROMETHEUS_PORT=4343

  # =============================================================================
  # WAVE 3 - Voice clone + goal card + langdetect + ask-frame + diarize + semsearch
  # =============================================================================
  # Every wave-3 module is feature-flag gated. When a flag is off the module
  # is not constructed on room open and the corresponding UI stays hidden.

  # Chatterbox voice cloning via referenceAudioSrc={blobCoreKey, blobIndex}.
  # EN/IT ONLY - Chatterbox model does not support Indonesian.
  # Enables the "Clone my voice" button in RoomHeader for the host.
  # First-time model download is ~200 MB.
  CURVA_VOICE_CLONE_ENABLED=false

  # LLM structured output via responseFormat.json_schema (Qwen3 or Llama).
  # Parses free-text scoreboard readings into {minute, scorer, team, assist}.
  # Feeds the goal pipeline below. Reuses the shared LLM handle from commentator.
  CURVA_GOAL_CARD_ENABLED=false

  # @qvac/langdetect-text auto-routing for outgoing chat messages.
  # When a message language is detected with >0.6 confidence, the chat send
  # path picks the correct Bergamot pair without asking the user.
  CURVA_LANGDETECT_ENABLED=false

  # Ask-the-frame orchestration - VLM caption -> RAG ingest -> RAG search ->
  # LLM stream -> TTS. Enables the ? hotkey overlay above VideoPlayer.
  # Requires SmolVLM2 (~521 MB) and RAG embed model (~265 MB) first-run.
  CURVA_ASK_FRAME_ENABLED=false

  # Parakeet Sortformer diarized replay. Speaker turns rendered as a color
  # badge grid in CommentaryPanel (host-only start button). Requires Parakeet
  # STT models (~150 MB in addition to Whisper).
  CURVA_DIARIZE_ENABLED=false   

  # Semantic search via sdk.embed(). Enables the srch button in Chat
  # header and auto-indexes every incoming message into an in-memory LRU
  # (1024 entries). Reuses the RAG embed model.
  CURVA_SEMSEARCH_ENABLED=false 

  # =============================================================================
  # WAVE 4 - Apply middleware + goal pipeline + MobileNetV3 pre-filter
  # =============================================================================

  # Autobase apply middleware chain. OBSERVATIONAL wire-in via
  # base.on('update'). Composes auditLogMiddleware + chaosMiddleware +
  # systemGuardMiddleware + replayRecorderMiddleware around the reducer.
  # When OFF, boot is byte-identical to the pre-middleware path.
  CURVA_APPLY_MIDDLEWARE_ENABLED=false
  
  # Chaos middleware node-drop for divergence testing. Deterministic drop
  # using FNV-1a hash of canonical JSON so both peers make the same call.
  # Only meaningful when CURVA_APPLY_MIDDLEWARE_ENABLED=true.
  CURVA_CHAOS_ENABLED=false
  
  # Goal pipeline: OCR -> goalCard -> MCP -> Bergamot -> streaming TTS ->
  # Autobase system:goal-card broadcast. The marquee 6-capability demo flow.
  # Requires OCR_LATIN + goalCard + Bergamot + Supertonic all loaded.
  CURVA_GOAL_PIPELINE_ENABLED=false

  # MobileNetV3 pre-filter for VLM (via @qvac/classification-ggml).
  # When enabled, every VLM caption call first runs through classify() and
  # skips if the top label is "food" or confidence < 0.4. Saves ~90% of the
  # expensive SmolVLM2 cost on non-match frames. Tiny model (~15 MB).
  CURVA_VLM_PREFILTER_ENABLED=false
  
  # =============================================================================
  # Development / demo runtime knobs
  # =============================================================================
  # Force P2P traffic through a seeder relay instead of hole-punching directly.
  # REQUIRED when running two peers on the same laptop.
  CURVA_FORCE_RELAY=1
  
  # Portable identity via keet-identity-key 3.2.0. Enables verified-device
  # badge in Chat + RoomHeader.
  CURVA_KEET_IDENTITY_ENABLED=true
  
  # Autobase multi-writer (Pattern B). Enables promoting viewer peers to
  # indexed writers so chat is bidirectional. Off = read-only viewer chat.
  CURVA_MULTIWRITER=true
  
  # QVAC roomBot (LLM Q&A agent listening for /bot messages in chat).
  # Uses the shared LLM handle + MCP + RAG.
  CURVA_QVAC_BOT_ENABLED=false

   CURVA_VOICE_CLONE_GOAL_ENABLED=true
  CURVA_COMMENTATOR_VOICE_CLONE_ENABLED=true
  CURVA_MATCH_RECAP_ENABLED=true
  CURVA_AUTO_HIGHLIGHT_ENABLED=true
CURVA_VOICE_COACH_MEMORY_ENABLED=true   # default on
  CURVA_ROOM_SEARCH_ENABLED=true          # default on

    CURVA_COMMENTATOR_MULTI_LOCALE_ENABLED=true
  CURVA_QVAC_ASSET_SEED_ENABLED=true         # only if you want to demo P2P mesh
  CURVA_GOAL_PROOF_ENABLED=true              # only if you fix the clips bridge
  CURVA_VOICE_COACH_CROSS_LINGUAL_ENABLED=true  # defaults on
CURVA_COMMENTATOR_RAG_ENABLED=true      # F9 