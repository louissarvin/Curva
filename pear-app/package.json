{
  "name": "curva",
  "productName": "Curva",
  "version": "0.1.0",
  "upgrade": "pear://<CURVA_APP_KEY>",
  "description": "Watch the World Cup with friends, peer-to-peer.",
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "pear": {
    "name": "curva",
    "main": "electron/main.js",
    "links": [
      "pear://*",
      "https://*"
    ],
    "routes": {
      "/room": "/"
    },
    "unrouted": [
      "/electron",
      "/renderer",
      "/bare",
      "/workers",
      "/assets"
    ],
    "assets": {
      "branding": {
        "link": "pear://REPLACE_WITH_VERSIONED_LINK_AFTER_PEAR_STAGE",
        "name": "Curva branding pack (Curva Nord Jakarta and Curva Sud Torino crests, WC26 team crests)"
      }
    }
  },
  "scripts": {
    "start": "electron-forge start -- --no-updates",
    "start:updates": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "brittle-node test/*.test.js",
    "seed:peer-a": "electron-forge start -- --no-updates --storage ./.store-peer-a",
    "seed:peer-b": "electron-forge start -- --no-updates --storage ./.store-peer-b",
    "demo:4peer": "node scripts/demo-4peer.js",
    "pear:stage": "pear stage dev .",
    "pear:release": "pear release dev .",
    "pear:seed": "pear seed dev .",
    "postinstall": "node scripts/postinstall-noble-engines-fix.js && node scripts/postinstall-bare-node-shims.js"
  },
  "dependencies": {
    "@qvac/sdk": "^0.14.0",
    "@tetherto/wdk": "^1.0.0-beta.12",
    "@tetherto/wdk-secret-manager": "^1.0.0-beta.3",
    "@tetherto/wdk-wallet-evm-erc-4337": "^1.0.0-beta.10",
    "autobase": "^7.28.1",
    "b4a": "^1.8.1",
    "blind-peering": "^2.4.0",
    "corestore": "^7.11.0",
    "ethers": "^6.13.0",
    "framed-stream": "^1.0.1",
    "graceful-goodbye": "^1.3.3",
    "hyperbee": "^2.27.3",
    "hyperblobs": "^2.12.1",
    "hypercore-blob-server": "^1.15.0",
    "hypercore-crypto": "^3.7.0",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "keet-identity-key": "^3.2.0",
    "paparam": "^1.10.1",
    "pear-runtime": "^1.3.1",
    "qrcode": "^1.5.4",
    "which-runtime": "^1.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "brittle": "^4.0.2",
    "electron": "^40.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0"
  }
}
